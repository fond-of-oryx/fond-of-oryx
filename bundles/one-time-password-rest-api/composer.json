{
  "name": "fond-of-oryx/one-time-password-rest-api",
  "description": "Spryker One Time Password Rest Api Module.",
  "license": "MIT",
  "authors": [
    {
      "name": "Daniel Kemna",
      "email": "danielkemna@t-online.de"
    }
  ],
  "require": {
    "php": ">=7.3",
    "spryker/glue-application": "^1.0.0"
  },
  "require-dev": {
    "codeception/codeception": "^2.3",
    "fond-of-codeception/spryker": "^1.0.0",
    "mikey179/vfsstream": "^1.6",
    "phpro/grumphp": "^0.14",
    "sebastian/phpcpd": "^4.0",
    "spryker/code-sniffer": "^0.11",
    "spryker/development": "^3.6"
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "autoload": {
    "psr-4": {
      "FondOfOryx\\": "src/FondOfOryx/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "FondOfOryx\\": "tests/FondOfOryx/",
      "Generated\\": "tests/Generated/"
    }
  }
}
