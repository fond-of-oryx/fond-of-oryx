<?xml version="1.0"?>
<transfers xmlns="spryker:transfer-01"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="spryker:transfer-01 http://static.spryker.com/transfer-01.xsd">

    <transfer name="RestReturnLabelRequest">
        <property name="idCustomer" type="int" />
        <property name="companyUnitAddressUuid" type="string" />
    </transfer>

    <transfer name="RestReturnLabelResponse">
        <property name="errors" type="Message[]" singular="error"/>
        <property name="isSuccessful" type="bool"/>
        <property name="returnLabelResponse" type="ReturnLabelResponse"/>
    </transfer>

    <transfer name="ReturnLabelResponse">
        <property name="data" type="string" />
    </transfer>

    <transfer name="RestReturnLabelRequestAttributes">
        <property name="companyUnitAddressUuid" type="string" />
    </transfer>

    <transfer name="ReturnLabelRestApiResponse">
        <property name="returnLabel" type="string" />
    </transfer>

    <transfer name="RestUser">
        <property name="naturalIdentifier" type="string"/>
        <property name="surrogateIdentifier" type="int"/>
    </transfer>
</transfers>
