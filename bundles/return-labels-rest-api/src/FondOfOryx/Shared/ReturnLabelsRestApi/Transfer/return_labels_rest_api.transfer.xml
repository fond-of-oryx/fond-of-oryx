<?xml version="1.0"?>
<transfers xmlns="spryker:transfer-01"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="spryker:transfer-01 http://static.spryker.com/transfer-01.xsd">

    <transfer name="ReturnLabelsRestApi">
        <property name="customerId" type="int" />
        <property name="customerReference" type="string" />
        <property name="companyUserReference" type="string" />
        <property name="companyUnitAddressExternalReference" type="string" />
    </transfer>

    <transfer name="RestReturnLabelRequestAttributes">
        <property name="companyUserReference" type="string" />
        <property name="companyUnitAddressExternalReference" type="string" />
    </transfer>

    <transfer name="ReturnLabelRestApiResponse">
        <property name="returnLabel" type="string" />
    </transfer>

    <transfer name="RestUser">
        <property name="naturalIdentifier" type="string"/>
        <property name="surrogateIdentifier" type="int"/>
    </transfer>

    <transfer name="CompanyUnitAddress">
        <property name="companyUserReference" type="string"/>
        <property name="fkCompany" type="int"/>
    </transfer>

    <transfer name="CompanyUser">
        <property name="companyUnitAddress" type="CompanyUnitAddress"/>
    </transfer>

    <transfer name="CompanyUnitAddressResponse">
        <property name="companyUnitAddress" type="CompanyUnitAddress"/>
    </transfer>
</transfers>
