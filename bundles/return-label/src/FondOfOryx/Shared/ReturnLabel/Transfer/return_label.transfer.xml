<?xml version="1.0"?>
<transfers xmlns="spryker:transfer-01"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="spryker:transfer-01 http://static.spryker.com/transfer-01.xsd">

    <transfer name="CompanyUnitAddress">
    </transfer>

   <transfer name="ReturnLabelRequest">
       <property name="idCustomer" type="int"/>
       <property name="idCompanyUnitAddress" type="int"/>
   </transfer>

    <transfer name="ReturnLabelResponse">
        <property name="data" type="string" />
    </transfer>

    <transfer name="ReturnLabelServiceRequest">
        <property name="qrCode" type="bool"/>
        <property name="returnForm" type="bool"/>
        <property name="customer" type="ReturnLabelCustomer"/>
    </transfer>

    <transfer name="ReturnLabelCustomer">
        <property name="receiverId" type="string"/>
        <property name="customerReference" type="string"/>
        <property name="email" type="string"/>
        <property name="phone" type="string"/>
        <property name="address" type="ReturnLabelAddress"/>
    </transfer>

    <transfer name="ReturnLabelAddress">
        <property name="company" type="string"/>
        <property name="name1" type="string"/>
        <property name="name2" type="string"/>
        <property name="address1" type="string"/>
        <property name="address2" type="string"/>
        <property name="address3" type="string"/>
        <property name="zipCode" type="string"/>
        <property name="city" type="string"/>
        <property name="country" type="string"/>
        <property name="iso3code" type="string"/>
    </transfer>

    <transfer name="CompanyUnitAddress">
        <property name="name1" type="string"/>
        <property name="name2" type="string"/>
        <property name="address1" type="string"/>
        <property name="address2" type="string"/>
        <property name="address3" type="string"/>
        <property name="zipCode" type="string"/>
        <property name="city" type="string"/>
        <property name="country" type="string"/>
        <property name="fkCountry" type="int"/>
    </transfer>

    <transfer name="CompanyBusinessUnit">
        <property name="email" type="string"/>
        <property name="phone" type="string"/>
        <property name="company" type="Company"/>
    </transfer>

    <transfer name="Company">
        <property name="debtorNumber" type="string"/>
    </transfer>
</transfers>
