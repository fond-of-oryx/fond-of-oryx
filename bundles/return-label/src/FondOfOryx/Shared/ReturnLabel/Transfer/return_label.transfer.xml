<?xml version="1.0"?>
<transfers xmlns="spryker:transfer-01"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="spryker:transfer-01 http://static.spryker.com/transfer-01.xsd">

    <transfer name="CompanyUnitAddress">
    </transfer>

   <transfer name="ReturnLabelRequest">
       <property name="idCustomer" type="int"/>
       <property name="idCompanyUnitAddress" type="int"/>
   </transfer>

    <transfer name="ReturnLabelResponse">
        <property name="data" type="string" />
    </transfer>

    <transfer name="ReturnLabelServiceRequest">
        <property name="qrCode" type="bool"/>
        <property name="returnForm" type="bool"/>
        <property name="returnLabelAddress" type="ReturnLabelAddress"/>
    </transfer>

    <transfer name="ReturnLabelAddress">
        <property name="company" type="string"/>
        <property name="name" type="string"/>
        <property name="address1" type="string"/>
        <property name="address2" type="string"/>
        <property name="address3" type="string"/>
        <property name="zip" type="string"/>
        <property name="city" type="string"/>
        <property name="country" type="string"/>
    </transfer>
</transfers>
